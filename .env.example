# Postgres (Neon/Supabase). Prisma needs this at build & runtime.
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
# Exa search API key — https://dashboard.exa.ai
EXA_API_KEY="your-exa-key"
# Optional: required as x-refresh-secret when calling POST /api/news/refresh-all
# NEWS_REFRESH_SECRET="demo-refresh-secret"
