generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Article {
  id          String   @id @default(cuid())
  country     String
  title       String
  source      String
  url         String   @unique
  publishedAt DateTime
  snippet     String
  fetchedAt   DateTime @default(now())

  @@index([country])
}

model Country {
  name       String   @id
  flag       String
  capital    String
  region     String
  subregion  String
  languages  String
  population  Int
  fetchedAt  DateTime @default(now())
}
